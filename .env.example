# Application
APP_NAME=HawkNet-Ai
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database — SQLite for development; swap to Postgres for production:
# DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/public_safety
DATABASE_URL=sqlite:///db/app.db

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth
# SECURITY: Set AUTH_ENABLED=true and a strong JWT_SECRET before any production deployment.
# The server will REFUSE to start if ENVIRONMENT=production and JWT_SECRET is the default below.
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate limiting (per client IP, sliding 60-second window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Alerting
# Set to a real webhook URL to POST high-risk alerts there instead of the JSONL fallback.
# Example: ALERT_WEBHOOK_URL=https://your-endpoint.example.com/mha-alert
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5.0

# Call session TTL (seconds) — how long transcript chunks are retained in the DB
CALL_SESSION_TTL_SECONDS=3600

# Frontend
VITE_API_BASE_URL=http://localhost:8000
